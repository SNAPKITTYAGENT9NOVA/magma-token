# FORGE Token — Environment Variables
# Copy to .env and fill in before deploying

# Deployer wallet — must hold Base Sepolia ETH for gas
# Faucets: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
#          https://base-sepolia.optimism.io
DEPLOYER_PRIVATE_KEY=0x...

# Multisig — receives ARCHITECT_ROLE and DEFAULT_ADMIN_ROLE
ARCHITECT_ADDRESS=0x...

# Treasury — receives MINTER_ROLE, calls wormMint via settlement bridge
TREASURY_ADDRESS=0x...

# Basescan API key — for contract verification
BASESCAN_API_KEY=...
